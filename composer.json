{
    "name": "birdcode/bc-simplerate",
    "description": "Include rate feature for any record",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "keywords": [
        "TYPO3",
        "extension",
        "rate"
    ],
    "homepage": "https://extensions.typo3.org/extension/bc_simplerate",
    "support": {
        "source": "https://github.com/birdcode-rs/bc_simplerate",
        "issues": "https://github.com/birdcode-rs/bc_simplerate/issues"
    },
    "authors": [
        {
            "name": "Bird Dev",
            "role": "Developer",
            "email": "bird.dev@birdcode.in.rs",
            "homepage": "https://birdcode.tech"
        }
    ],
    "require": {
        "php": "^8.3 || ^8.4",
        "typo3/cms-frontend": "^13.4.5 || ^14.0"
    },
    "autoload": {
        "psr-4": {
            "BirdCode\\BcSimplerate\\": "Classes/"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "web-dir": ".Build/Web",
            "app-dir": ".Build",
            "extension-key": "bc_simplerate"
        }
    }
}